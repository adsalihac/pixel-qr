{
  "expo": {
    "name": "PixelQR",
    "slug": "pixel-qr",
    "scheme": "pixelqr",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F4ACB"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "pwa": {
        "serviceWorkerPath": "/sw.js"
      }
    },
    "extra": {
      "pwa": {
        "name": "PixelQR",
        "shortName": "PixelQR",
        "description": "Beautiful, scan-safe QR code generator",
        "startUrl": "/",
        "display": "standalone",
        "backgroundColor": "#FFFDF5",
        "themeColor": "#FF6B6B",
        "orientation": "portrait"
      }
    },
    "plugins": [
      "expo-router"
    ]
  }
}
